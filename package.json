{
	"name": "jzimhttp",
	"version": "1.0.0",
	"description": "HTTP server for ZIM files — browser UI and MCP tools",
	"type": "module",
	"main": "dist/main.js",
	"bin": {
		"jzimhttp": "dist/main.js"
	},
	"scripts": {
		"build": "npm run build:daemon && npm run build:tests",
		"build:daemon": "tsc -p tsconfig.json",
		"build:tests": "tsc -p tests/tsconfig.json",
		"run:tests": "ava",
		"run:tests-watch": "ava --watch"
	},
	"ava": {
		"files": [
			"tests/dist/**/*.test.js"
		],
		"timeout": "30s"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.11",
		"@openzim/libzim": "^4.1.0",
		"hono": "^4.12.9",
		"node-html-parser": "^7.1.0",
		"turndown": "^7.2.2"
	},
	"devDependencies": {
		"@types/node": "^20.19.37",
		"@types/turndown": "^5.0.6",
		"ava": "^6.4.1",
		"c8": "^9.1.0",
		"typescript": "^5.9.3"
	}
}
